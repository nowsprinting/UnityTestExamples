      "Bash(gh api *)",
      "Bash(gh issue *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(rg *)",
      "Bash(python3 --version)",
      "Bash(node --version)",
      "Bash(gradle *)",
      "Bash(java *)",
      "Bash(jar *)",
      "Bash(unzip *)",
      "Bash(javap *)",
      "Bash(find *)",
      "WebSearch",
