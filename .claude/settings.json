      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git remote *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(git status *)",
      "Bash(git branch --show-current)",
      "Bash(ls *)",
      "Bash(mkdir *)",
